# ── Predict risk ──────────────────────────────────────────────────────────
user_df     = pd.DataFrame([user_patient])[FEATURE_NAMES]
user_scaled = scaler.transform(user_df)
user_proba  = rf_model.predict_proba(user_scaled)[0]
